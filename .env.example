# =============================================================================
# StoryVerse AI — Environment Variables
# Copy to `.env` for local development. Never commit real secrets.
# =============================================================================

# --- Required for Phase A (auth + database) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/storyverse?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# App origin (no trailing slash)
# Local:  http://localhost:3000
# Prod:   https://aftionix.tech
AUTH_URL="http://localhost:3000"

# Required behind Nginx / Docker reverse proxies
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI:
#   Local: http://localhost:3000/api/auth/callback/google
#   Prod:  https://aftionix.tech/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Docker Compose Postgres (production VPS) ---
POSTGRES_USER=storyverse
POSTGRES_PASSWORD=
POSTGRES_DB=storyverse
# Inside Docker network use host "db":
# DATABASE_URL="postgresql://storyverse:PASSWORD@db:5432/storyverse?schema=public"

# --- AI provider (switch with AI_PROVIDER; restart/redeploy required) ---
# Supported in production: gemini | openai
# AI_PROVIDER=local is REJECTED (not ready). See docs/future-local-provider.md
AI_PROVIDER=gemini

# Controlled failover (sequential — never parallel). Defaults:
#   primary = AI_PROVIDER, fallback = the other live provider when its key is set
# AI_PROVIDER_PRIMARY=openai
# AI_PROVIDER_FALLBACK=gemini
# Set FALLBACK=none to disable failover
# AI_PROVIDER_FALLBACK=none

# Gemini (when AI_PROVIDER=gemini or fallback)
GEMINI_API_KEY=
GEMINI_STORY_MODEL=gemini-3.1-flash-lite
GEMINI_SUMMARY_MODEL=gemini-3.1-flash-lite
GEMINI_AGENT_MODEL=gemini-3.1-flash-lite
# Optional override for creative prose (defaults to GEMINI_STORY_MODEL)
# GEMINI_CREATIVE_MODEL=gemini-3.1-flash-lite

# OpenAI (when AI_PROVIDER=openai or fallback)
OPENAI_API_KEY=
OPENAI_STORY_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5-nano
OPENAI_AGENT_MODEL=gpt-5-mini
# Optional override for creative prose (defaults to OPENAI_STORY_MODEL)
# OPENAI_CREATIVE_MODEL=gpt-5-mini

AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10

# Phase B — unified hybrid intent router (LLM classifier only for low confidence)
# When disabled, deterministic + contextual routing still works (no provider call).
AI_INTENT_CLASSIFIER_ENABLED=true
AI_INTENT_CONFIDENCE_THRESHOLD=0.55
# Optional small/fast model override (defaults to summary/agent model)
# AI_INTENT_CLASSIFIER_MODEL=
AI_INTENT_CLASSIFIER_TIMEOUT_MS=4000

# Phase D — Dynamic Context Builder v2 (operation-scoped memory slices for prompts)
# When disabled, falls back to legacy buildStoryContext behavior.
AI_DYNAMIC_CONTEXT_V2_ENABLED=true

# Phase E — Prompt Registry v2 (canonical prompt IDs + layered composers)
# When disabled, falls back to legacy prompt builders.
AI_PROMPT_REGISTRY_V2_ENABLED=true

# Phase F — Provider Router v2 (unified generation gateway)
# When disabled, falls back to legacy generateWithFailover / direct getAIProvider.
AI_PROVIDER_ROUTER_V2_ENABLED=true
AI_PROVIDER_CIRCUIT_BREAKER_ENABLED=true

# Phase G — Story Tool Framework (AI plans ToolRequests; app executes tools)
# When disabled, Phase A–F memoryPatch path remains.
AI_STORY_TOOL_FRAMEWORK_ENABLED=false

# Phase G.5 — Instruction Fidelity (locked facts, readiness, output validation)
# When disabled, Phase A–G behavior is unchanged.
AI_INSTRUCTION_FIDELITY_V1_ENABLED=false

# Optional model profile overrides (defaults map to existing *_AGENT/_CREATIVE/_SUMMARY models)
# OPENAI_MODEL_FAST=
# OPENAI_MODEL_BALANCED=
# OPENAI_MODEL_CREATIVE=
# OPENAI_MODEL_LONG_CREATIVE=
# OPENAI_MODEL_JSON_FAST=
# GEMINI_MODEL_FAST=
# GEMINI_MODEL_BALANCED=
# GEMINI_MODEL_CREATIVE=
# GEMINI_MODEL_LONG_CREATIVE=
# GEMINI_MODEL_JSON_FAST=

# Offline unit tests may use AI_PROVIDER=mock (NOT allowed in production).
# Prefer setAIProviderOverride() in Vitest instead.

# Health check (never prints API keys):
#   npm run ai:health
#   AI_PROVIDER=openai npm run ai:health
