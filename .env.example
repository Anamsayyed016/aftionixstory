# =============================================================================
# StoryVerse AI — Environment Variables
# Copy to `.env` for local development. Never commit real secrets.
# =============================================================================

# --- Required for Phase A (auth + database) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/storyverse?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# App origin (no trailing slash)
# Local:  http://localhost:3000
# Prod:   https://aftionix.tech
AUTH_URL="http://localhost:3000"

# Required behind Nginx / Docker reverse proxies
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI:
#   Local: http://localhost:3000/api/auth/callback/google
#   Prod:  https://aftionix.tech/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Docker Compose Postgres (production VPS) ---
POSTGRES_USER=storyverse
POSTGRES_PASSWORD=
POSTGRES_DB=storyverse
# Inside Docker network use host "db":
# DATABASE_URL="postgresql://storyverse:PASSWORD@db:5432/storyverse?schema=public"

# --- AI provider (switch with AI_PROVIDER only; restart/redeploy required) ---
# Supported in production: gemini | openai
# AI_PROVIDER=local is REJECTED (not ready). See docs/future-local-provider.md
AI_PROVIDER=gemini

# Gemini (when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_STORY_MODEL=gemini-3.1-flash-lite
GEMINI_SUMMARY_MODEL=gemini-3.1-flash-lite
GEMINI_AGENT_MODEL=gemini-3.1-flash-lite
# Optional override for creative prose (defaults to GEMINI_STORY_MODEL)
# GEMINI_CREATIVE_MODEL=gemini-3.1-flash-lite

# OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_STORY_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5-nano
OPENAI_AGENT_MODEL=gpt-5-mini
# Optional override for creative prose (defaults to OPENAI_STORY_MODEL)
# OPENAI_CREATIVE_MODEL=gpt-5-mini

AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10

# Offline unit tests may use AI_PROVIDER=mock (NOT allowed in production).
# Prefer setAIProviderOverride() in Vitest instead.

# Health check (never prints API keys):
#   npm run ai:health
#   AI_PROVIDER=openai npm run ai:health
